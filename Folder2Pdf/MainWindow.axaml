<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Folder2Pdf.MainWindow"
        Title="Folder2PDF"
        Width="780"
        Height="850"
        MinWidth="560"
        MinHeight="520"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto,*" Margin="28">

        <!-- ── Top: inputs + controls ── -->
        <StackPanel Grid.Row="0" Spacing="16">

            <!-- Header -->
            <!-- <StackPanel Margin="0,0,0,4"> -->
            <!--     <TextBlock Text="Folder2PDF" -->
            <!--                FontSize="28" -->
            <!--                FontWeight="Bold" /> -->
            <!--     <TextBlock Text="Convert source code folders to PDF or plain text" -->
            <!--                FontSize="13" -->
            <!--                Foreground="#8B8B9E" -->
            <!--                Margin="0,4,0,0" /> -->
            <!-- </StackPanel> -->

            <!-- Source Folders Card -->
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="SOURCE FOLDERS" Classes="section-header" />
                    <ListBox x:Name="FolderList"
                             MinHeight="72"
                             MaxHeight="120"
                             SelectionMode="Multiple" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Add Folder&#x2026;" Click="AddFolder_Click" />
                        <Button Content="Remove Selected" Click="RemoveFolder_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Settings Card -->
            <Border Classes="card">
                <StackPanel Spacing="14">
                    <TextBlock Text="SETTINGS" Classes="section-header" />

                    <!-- Options row 1 -->
                    <WrapPanel Orientation="Horizontal">
                        <CheckBox x:Name="IncludeHeadersCheck"
                                  Content="Include file paths as headers"
                                  IsChecked="True"
                                  Margin="0,0,16,0" />
                        <CheckBox x:Name="SeparateBySourceCheck"
                                  Content="Separate output by source folder"
                                  IsChecked="True"
                                  Margin="0,0,16,0"
                                  Click="SeparateBySource_Changed" />
                        <CheckBox x:Name="TimestampCheck"
                                  Content="Add timestamp to filename"
                                  IsChecked="False" />
                    </WrapPanel>

                    <!-- Output format -->
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Format" FontWeight="SemiBold" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,4,0" />
                        <RadioButton x:Name="FormatPdf"
                                     Content=".pdf"
                                     GroupName="OutputFormat"
                                     IsChecked="True"
                                     Click="Format_Changed" />
                        <RadioButton x:Name="FormatTxt"
                                     Content=".txt"
                                     GroupName="OutputFormat"
                                     Click="Format_Changed" />
                        <RadioButton x:Name="FormatMd"
                                     Content=".md"
                                     GroupName="OutputFormat"
                                     Click="Format_Changed" />
                        <RadioButton x:Name="FormatOther"
                                     Content="Other"
                                     GroupName="OutputFormat"
                                     Click="Format_Changed" />
                        <TextBox x:Name="CustomFormatBox"
                                 Watermark=".js"
                                 Width="80"
                                 IsVisible="False"
                                 VerticalAlignment="Center"
                                 TextChanged="Format_Changed" />
                    </StackPanel>

                    <Border Classes="divider" />

                    <!-- Extensions + Output Path in one row -->
                    <Grid ColumnDefinitions="*,16,1.5*">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="File Extensions" FontWeight="SemiBold" FontSize="13" />
                            <ComboBox x:Name="ExtensionsCombo"
                                      HorizontalAlignment="Stretch"
                                      SelectedIndex="0"
                                      SelectionChanged="Extensions_Changed">
                                <ComboBoxItem Content="All supported (default)" />
                                <ComboBoxItem Content=".pdf" />
                                <ComboBoxItem Content=".txt" />
                                <ComboBoxItem Content=".md" />
                                <ComboBoxItem Content=".py" />
                                <ComboBoxItem Content=".js" />
                                <ComboBoxItem Content="Other…" />
                            </ComboBox>
                            <TextBox x:Name="CustomExtensionsBox"
                                     Watermark=".cs, .java, .go, &#x2026;"
                                     IsVisible="False" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="6">
                            <TextBlock x:Name="OutputLabel" Text="Output File" FontWeight="SemiBold" FontSize="13" />
                            <Grid ColumnDefinitions="*,8,Auto">
                                <TextBox Grid.Column="0"
                                         x:Name="OutputPathBox"
                                         Watermark="Leave blank to auto-generate" />
                                <Button Grid.Column="2"
                                        Content="Browse&#x2026;"
                                        Click="BrowseOutput_Click" />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="3*,8,*">
                <Button Grid.Column="0"
                        x:Name="ConvertButton"
                        Content="Export to PDF"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Padding="0,14"
                        CornerRadius="10"
                        Click="Convert_Click">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackground" Color="#6366F1" />
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#818CF8" />
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#4F46E5" />
                        <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#E0E0FF" />
                    </Button.Resources>
                </Button>
                <Button Grid.Column="2"
                        x:Name="OpenFolderButton"
                        Content="Open Folder"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Padding="0,14"
                        CornerRadius="10"
                        IsVisible="False"
                        Click="OpenFolder_Click" />
            </Grid>

            <!-- Progress -->
            <ProgressBar x:Name="ProgressBar"
                         Minimum="0"
                         Maximum="100"
                         Value="0"
                         Height="6"
                         CornerRadius="3"
                         IsVisible="False" />
            <TextBlock x:Name="ProgressLabel"
                       Text=""
                       HorizontalAlignment="Center"
                       FontSize="12"
                       Foreground="#8B8B9E"
                       IsVisible="False" />

        </StackPanel>

        <!-- ── Bottom: status log ── -->
        <Border Grid.Row="1" Classes="card" Margin="0,16,0,0">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0"
                           Text="LOG"
                           Classes="section-header" />
                <TextBox Grid.Row="1"
                         x:Name="StatusLog"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         FontFamily="Cascadia Code,JetBrains Mono,Courier New,monospace"
                         FontSize="12"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
            </Grid>
        </Border>

    </Grid>
</Window>
